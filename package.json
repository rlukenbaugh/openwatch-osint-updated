{
  "name": "openwatch-osint",
  "version": "0.1.0",
  "description": "Desktop OSINT workspace for public-source monitoring, maps, webcams, and mission launch.",
  "author": "Luken",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:web": "node -e \"const fs=require('fs'); if (fs.existsSync('.next')) fs.rmSync('.next',{recursive:true,force:true});\" && npm run db:prepare:sqlite && next build && npm run prepare:electron",
    "build:win": "npm run build:web && electron-builder --win nsis",
    "start": "next start",
    "start:desktop": "electron .",
    "lint": "eslint src --ext .ts,.tsx",
    "prepare:electron": "node scripts/prepare-electron.mjs",
    "dist:win": "npm run build:win",
    "dist:dir": "npm run build:web && electron-builder --dir",
    "dist:exe": "npm run build:web && electron-packager . OpenWatch-OSINT --platform=win32 --arch=x64 --out=dist --overwrite --asar.unpackDir=electron-build --prune=true --ignore=\"^.*[\\\\/]openwatch-osint[\\\\/](dist|release)([\\\\/]|$)\"",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:prepare:sqlite": "node scripts/prepare-sqlite-db.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^4.5.3",
    "gridstack": "^12.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.482.0",
    "next": "^15.2.0",
    "next-themes": "^0.4.4",
    "openai": "^4.87.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.14",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.2",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.2.0",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "build": {
    "appId": "com.openwatch.osint",
    "productName": "OpenWatch OSINT",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron-build/standalone/server.js",
        "to": "server/server.js"
      },
      {
        "from": "electron-build/standalone/package.json",
        "to": "server/package.json"
      },
      {
        "from": "electron-build/standalone/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron-build/standalone/.next",
        "to": "server/.next",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron-build/standalone/prisma/app.db",
        "to": "server/prisma/app.db"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "openwatch-osint-${version}-setup.${ext}"
    }
  }
}
