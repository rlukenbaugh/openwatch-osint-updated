# Prisma (SQLite for MVP local persistence)
DATABASE_URL="file:./dev.db"

# Optional: used by AI analyst route. Leave empty to run in local fallback mode.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Optional feed API helpers (public/demo-safe)
ALPHA_VANTAGE_API_KEY=""

# Webcam provider connectors
OHGO_API_KEY=""
OHGO_API_BASE_URL="https://publicapi.ohgo.com"
FAA_WEATHERCAMS_API_KEY=""
FAA_WEATHERCAMS_API_URL="https://weathercams.faa.gov/api"
